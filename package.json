{
	"name": "max_assistant",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run src/assistant.ts",
		"build": "bun build src/assistant.ts --outfile assistant.js --target node --external max-api",
		"format": "bunx biome format --write",
